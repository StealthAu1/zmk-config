/* Custom Defined Behaviors */
/ {
behaviors {
    mousedance: mousedance {
        compatible = "zmk,behavior-tap-dance";
        #binding-cells = <0>;
        tapping-term-ms = <200>;
        bindings = <&mo 3>, <&to 3>;
    };



    shiftdance: shiftdance {
        compatible = "zmk,behavior-tap-dance";
        #binding-cells = <0>;
        tapping-term-ms = <200>;
        bindings = <&sk RSHIFT>, <&kp CAPSLOCK>;
    };


    numdance: numdance {
        compatible = "zmk,behavior-tap-dance";
        #binding-cells = <0>;
        tapping-term-ms = <200>;
        bindings = <&mo 5>, <&to 5>;
    };
};

};

